# Windows code signing configuration for electron-builder
# Copy values into your CI/CD secret store (recommended) or shell env before release.

# Base64/PFX URL or file reference supported by electron-builder
CSC_LINK=

# Password for the PFX certificate referenced by CSC_LINK
CSC_KEY_PASSWORD=

# Optional: set true to run unsigned release flow (not recommended for production)
ALLOW_UNSIGNED_WINDOWS_RELEASE=false
