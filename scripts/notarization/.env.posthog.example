# Copy to .env.posthog (gitignored) on your build machine to enable anonymous
# usage analytics in shipped DMGs. Leave absent in open-source builds.
#
# The phc_ prefix is a PostHog client/write-only key, designed for embedding
# in client apps. It can fire events but cannot read any data from your
# project. See https://posthog.com/docs/api#authentication for details.
#
# Anonymous metrics are gated by the user's Settings → Privacy toggle (on by
# default). Transcription text is NEVER sent — only coarse signals like word
# count, audio length, and model name.

POSTHOG_API_KEY=phc_your_key_here
